# Auth0 core app settings
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_regular_web_app_client_id
AUTH0_CLIENT_SECRET=your_regular_web_app_client_secret
AUTH0_SECRET=replace_with_a_64_char_hex_secret
APP_BASE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/auth0-demo?retryWrites=true&w=majority
MONGODB_DB=auth0-demo

# Optional: Auth0 audience for additional APIs
AUTH0_AUDIENCE=

# Recommended for Auth0 My Account / My Organization proxy with DPoP
AUTH0_DPOP_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_PUBLIC_KEY\n-----END PUBLIC KEY-----"
AUTH0_DPOP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_PRIVATE_KEY\n-----END PRIVATE KEY-----"
AUTH0_DPOP_CLOCK_SKEW=0
AUTH0_DPOP_CLOCK_TOLERANCE=30
AUTH0_RETRY_DELAY=100
AUTH0_RETRY_JITTER=true

# Optional cookie overrides
AUTH0_COOKIE_SECURE=false
AUTH0_COOKIE_SAME_SITE=Lax

# Optional MFA context tuning
AUTH0_MFA_CONTEXT_TTL=600
